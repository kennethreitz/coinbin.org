{
  "name": "coinbin.org",
  "scripts": {
  },
  "env": {
    "API_KEYS": {
      "description": "Colon-separated keys granting access to the pro history database.",
      "required": false
    },
    "COINGECKO_API_KEY": {
      "description": "Optional CoinGecko Pro API key.",
      "required": false
    },
    "FORECASTS_ENABLED": {
      "description": "Set to 1 to enable the (heavy) /forecast endpoints.",
      "required": false
    },
    "SENTRY_DSN": {
      "description": "Optional Sentry error reporting DSN.",
      "required": false
    },
    "WEB_CONCURRENCY": {
      "required": false
    }
  },
  "formation": {
  },
  "addons": [
    "heroku-postgresql"
  ],
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
